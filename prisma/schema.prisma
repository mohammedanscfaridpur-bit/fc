// Mohammedan Sporting Club, Faridpur — Database schema
// Provider: PostgreSQL (e.g. Aiven free tier)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Admin & auth
// ---------------------------------------------------------------------------

enum AdminRole {
  SUPER_ADMIN
  EDITOR
}

model AdminUser {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         AdminRole @default(EDITOR)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("admin_users")
}

// ---------------------------------------------------------------------------
// Leadership — current President & Secretary (each with a "Read more" page)
// ---------------------------------------------------------------------------

enum LeadershipRole {
  PRESIDENT
  SECRETARY
}

model Leadership {
  id           String         @id @default(cuid())
  role         LeadershipRole
  name         String
  nameBn       String
  designation  String? // e.g. "General Secretary"
  designationBn String?
  photo        String?
  shortBio     String         @db.Text
  shortBioBn   String         @db.Text
  fullBio      String?        @db.Text
  fullBioBn    String?        @db.Text
  tenureStart  DateTime?
  isCurrent    Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([role, isCurrent])
  @@map("leadership")
}

// ---------------------------------------------------------------------------
// Executive committee (current)
// ---------------------------------------------------------------------------

model CommitteeMember {
  id             String   @id @default(cuid())
  name           String
  nameBn         String
  designation    String
  designationBn  String
  photo          String?
  bio            String?  @db.Text
  bioBn          String?  @db.Text
  displayOrder   Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([displayOrder])
  @@map("committee_members")
}

// ---------------------------------------------------------------------------
// Former Presidents / Former Secretaries (historical record)
// ---------------------------------------------------------------------------

model FormerLeader {
  id          String         @id @default(cuid())
  role        LeadershipRole
  name        String
  nameBn      String
  photo       String?
  tenureStart Int // year
  tenureEnd   Int? // year, null = ongoing/unknown
  note        String?        @db.Text
  noteBn      String?        @db.Text
  displayOrder Int           @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([role, displayOrder])
  @@map("former_leaders")
}

// ---------------------------------------------------------------------------
// Life members
// ---------------------------------------------------------------------------

model LifeMember {
  id           String   @id @default(cuid())
  name         String
  nameBn       String
  memberSince  Int // year
  photo        String?
  occupation   String?
  occupationBn String?
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([displayOrder])
  @@map("life_members")
}

// ---------------------------------------------------------------------------
// History timeline
// ---------------------------------------------------------------------------

model HistoryMilestone {
  id           String   @id @default(cuid())
  year         Int
  title        String
  titleBn      String
  description  String   @db.Text
  descriptionBn String  @db.Text
  image        String?
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([year])
  @@map("history_milestones")
}

// ---------------------------------------------------------------------------
// Achievements
// ---------------------------------------------------------------------------

model Achievement {
  id           String   @id @default(cuid())
  year         Int
  title        String
  titleBn      String
  description  String?  @db.Text
  descriptionBn String? @db.Text
  image        String?
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([year])
  @@map("achievements")
}

// ---------------------------------------------------------------------------
// Activities (club programs — football, cricket, youth development, etc.)
// ---------------------------------------------------------------------------

model Activity {
  id           String   @id @default(cuid())
  title        String
  titleBn      String
  description  String   @db.Text
  descriptionBn String  @db.Text
  icon         String? // lucide icon name, e.g. "trophy"
  image        String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([displayOrder])
  @@map("activities")
}

// ---------------------------------------------------------------------------
// News
// ---------------------------------------------------------------------------

model NewsPost {
  id           String    @id @default(cuid())
  slug         String    @unique
  title        String
  titleBn      String
  excerpt      String    @db.Text
  excerptBn    String    @db.Text
  content      String    @db.Text
  contentBn    String    @db.Text
  coverImage   String?
  authorName   String?
  isPublished  Boolean   @default(false)
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([isPublished, publishedAt])
  @@map("news_posts")
}

// ---------------------------------------------------------------------------
// Events
// ---------------------------------------------------------------------------

enum EventStatus {
  UPCOMING
  ONGOING
  PAST
}

model EventPost {
  id           String      @id @default(cuid())
  slug         String      @unique
  title        String
  titleBn      String
  description  String      @db.Text
  descriptionBn String     @db.Text
  coverImage   String?
  location     String?
  locationBn   String?
  startDate    DateTime
  endDate      DateTime?
  status       EventStatus @default(UPCOMING)
  isFeatured   Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([startDate, status])
  @@map("event_posts")
}

// ---------------------------------------------------------------------------
// Gallery
// ---------------------------------------------------------------------------

model GalleryImage {
  id           String   @id @default(cuid())
  title        String?
  titleBn      String?
  imageUrl     String
  category     String? // e.g. "Match Day", "Training", "Ceremony"
  displayOrder Int      @default(0)
  uploadedAt   DateTime @default(now())

  @@index([category])
  @@map("gallery_images")
}

// ---------------------------------------------------------------------------
// Sponsors
// ---------------------------------------------------------------------------

enum SponsorTier {
  TITLE
  GOLD
  SILVER
  PARTNER
}

model Sponsor {
  id           String      @id @default(cuid())
  name         String
  logo         String
  website      String?
  tier         SponsorTier @default(PARTNER)
  displayOrder Int         @default(0)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([tier, displayOrder])
  @@map("sponsors")
}

// ---------------------------------------------------------------------------
// Site-wide contact info (singleton row, id fixed to "main")
// ---------------------------------------------------------------------------

model ContactInfo {
  id            String   @id @default("main")
  address       String   @db.Text
  addressBn     String   @db.Text
  phone         String
  alternatePhone String?
  email         String
  mapEmbedUrl   String?  @db.Text
  facebookUrl   String?
  youtubeUrl    String?
  instagramUrl  String?
  officeHours   String?
  officeHoursBn String?
  updatedAt     DateTime @updatedAt

  @@map("contact_info")
}

// ---------------------------------------------------------------------------
// Membership applications (submitted via public form, reviewed in admin)
// ---------------------------------------------------------------------------

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model MembershipApplication {
  id           String            @id @default(cuid())
  fullName     String
  fatherOrGuardianName String?
  dateOfBirth  DateTime?
  address      String            @db.Text
  phone        String
  email        String?
  occupation   String?
  photo        String?
  message      String?           @db.Text
  status       ApplicationStatus @default(PENDING)
  reviewNote   String?           @db.Text
  submittedAt  DateTime          @default(now())
  reviewedAt   DateTime?

  @@index([status, submittedAt])
  @@map("membership_applications")
}

// ---------------------------------------------------------------------------
// Contact form submissions (from the public Contact page)
// ---------------------------------------------------------------------------

model ContactMessage {
  id         String   @id @default(cuid())
  name       String
  email      String
  phone      String?
  subject    String?
  message    String   @db.Text
  isRead     Boolean  @default(false)
  submittedAt DateTime @default(now())

  @@index([isRead, submittedAt])
  @@map("contact_messages")
}
