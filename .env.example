# --- Database (MySQL — matches Hostinger's Node.js-enabled hosting plans) ---
DATABASE_URL="mysql://msc_user:CHANGE_ME@localhost:3306/msc_faridpur"

# --- NextAuth (Admin Dashboard) ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# --- Site ---
NEXT_PUBLIC_SITE_URL="https://mohammeda-sc-faridpur.com"
NEXT_PUBLIC_SITE_NAME="Mohammeda Sporting Club, Faridpur"

# --- Contact form / membership form email delivery ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
CONTACT_RECEIVER_EMAIL=""

# --- Google Map ---
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=""

# --- File uploads (gallery, committee photos, news images) ---
# Local disk path on the VPS (configured in Step 7 — Deployment)
UPLOAD_DIR="./public/uploads"
